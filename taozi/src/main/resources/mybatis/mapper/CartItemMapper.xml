<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taozi.mapper.CartItemMapper">

    <resultMap id="cartItemMap" type="com.taozi.entity.CartItem">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="productId" column="product_id"/>
        <result property="quantity" column="quantity"/>
        <association property="product" javaType="com.taozi.entity.Product">
            <id property="id" column="p_id"/>
            <result property="name" column="p_name"/>
            <result property="description" column="p_description"/>
            <result property="price" column="p_price"/>
            <result property="stock" column="p_stock"/>
            <result property="image" column="p_image"/>
            <result property="categoryId" column="p_category_id"/>
        </association>
    </resultMap>

    <select id="findByUserId" resultMap="cartItemMap">
        SELECT c.id, c.user_id, c.product_id, c.quantity,
               p.id p_id, p.name p_name, p.description p_description,
               p.price p_price, p.stock p_stock, p.image p_image, p.category_id p_category_id
        FROM cart_item c
        JOIN product p ON c.product_id = p.id
        WHERE c.user_id = #{userId}
    </select>

    <select id="findByUserIdAndProductId" resultType="com.taozi.entity.CartItem">
        SELECT * FROM cart_item WHERE user_id = #{userId} AND product_id = #{productId}
    </select>

    <insert id="insert" parameterType="com.taozi.entity.CartItem" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO cart_item (user_id, product_id, quantity)
        VALUES (#{userId}, #{productId}, #{quantity})
    </insert>

    <update id="updateQuantity">
        UPDATE cart_item SET quantity = #{quantity} WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM cart_item WHERE id = #{id}
    </delete>

    <delete id="deleteByUserId">
        DELETE FROM cart_item WHERE user_id = #{userId}
    </delete>

</mapper>
