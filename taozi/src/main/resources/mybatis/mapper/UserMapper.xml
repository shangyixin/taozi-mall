<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taozi.mapper.UserMapper">

    <select id="findByUsername" resultType="com.taozi.entity.User">
        SELECT * FROM `user` WHERE username = #{username}
    </select>

    <select id="findById" resultType="com.taozi.entity.User">
        SELECT * FROM `user` WHERE id = #{id}
    </select>

    <select id="findAll" resultType="com.taozi.entity.User">
        SELECT * FROM `user` ORDER BY id DESC
    </select>

    <insert id="insert" parameterType="com.taozi.entity.User" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `user` (username, password, email, phone, role)
        VALUES (#{username}, #{password}, #{email}, #{phone}, #{role})
    </insert>

    <update id="update" parameterType="com.taozi.entity.User">
        UPDATE `user`
        SET username=#{username}, email=#{email}, phone=#{phone}, role=#{role}
        WHERE id=#{id}
    </update>

    <delete id="delete">
        DELETE FROM `user` WHERE id=#{id}
    </delete>

</mapper>
